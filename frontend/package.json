{
  "name": "lightrag-webui",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "pgvector-proxy": "node scripts/pgvector-proxy.cjs",
    "dev:full": "npm run pgvector-proxy & vite",
    "db:backup": "node scripts/db-backup.cjs",
    "db:cleanup": "node scripts/db-cleanup.cjs",
    "db:restore": "node scripts/db-restore.cjs",
    "db:scheduler": "node scripts/db-scheduler.cjs",
    "db:status": "node scripts/db-stats.cjs",
    "db:api": "node scripts/db-management-api.cjs",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "playwright:install": "playwright install",
    "lint": "eslint src --ext .js,.ts",
    "lint:fix": "eslint src --ext .js,.ts --fix",
    "format": "prettier --write \"src/**/*.{js,ts,css,html}\""
  },
  "dependencies": {
    "jspdf": "^4.2.0",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^20.11.0",
    "@types/pg": "^8.18.0",
    "eslint": "^8.56.0",
    "playwright": "^1.58.2",
    "prettier": "^3.2.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vitest": "^1.2.0"
  }
}
