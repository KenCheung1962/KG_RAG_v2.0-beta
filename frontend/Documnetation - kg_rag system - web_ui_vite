  Type Safety

  // src/api/types.ts
  interface Document {
    doc_id: string;
    filename: string;
    status?: string;
  }

  // Now all documents are type-checked!
  async function uploadDocument(file: File): Promise<Document> {
    // ...
  }

  Clean Imports

  // Before (global scope)
  const result = await fetch('/api/v1/chat', ...);

  // After (explicit imports)
  import { sendQuery } from '@/api';
  const result = await sendQuery({ message, mode });

  Modular State

  // src/stores/appStore.ts
  export function addSelectedFile(file: File): void {
    const exists = state.selectedFiles.some(
      f => f.name === file.name && f.size === file.size
    );
    if (!exists) {
      state.selectedFiles.push(file);
      notifyListeners(); // Reactivity
    }
  }

  Component Structure

