# ============ Multi-Step Comprehensive Generation ============

async def generate_comprehensive_response(
    query: str,
    context: str,
    base_system_prompt: str,
    target_words: str,
    max_sections: int = 6
) -> str:
    """
    Multi-step generation for ultra-comprehensive responses.
    First creates an outline, then expands each section.
    """
    from minimax_fixed import deepseek_complete
    
    rerank_logger.info(f"Starting multi-step generation for '{query[:50]}...' targeting {target_words} words")
    
    # Step 1: Generate detailed outline
    outline_prompt = f"""Create a detailed outline for a comprehensive technical article about: {query}

Context from knowledge base:
{context[:3000]}

Requirements:
- Target length: {target_words} words
- Create 5-7 major sections
- Each section should have 3-5 subsections
- Include specific topics, concepts, and examples to cover

Output ONLY the outline in this format:
# [Title]
## 1. [Section Name]
- Point 1
- Point 2
- Point 3
## 2. [Section Name]
...etc"""

    try:
        outline = await deepseek_complete(
            prompt=outline_prompt,
            system_prompt="You are an expert at structuring technical documentation. Create detailed, comprehensive outlines.",
            model="deepseek-chat",
            max_tokens=2000,
            temperature=0.3
        )
        rerank_logger.info(f"Generated outline with {len(outline.split(chr(10)))} lines")
    except Exception as e:
        rerank_logger.error(f"Failed to generate outline: {e}")
        # Fallback to single-step generation
        return await deepseek_complete(
            prompt=f"Write a comprehensive article about: {query}\n\nContext:\n{context[:4000]}\n\nTarget: {target_words} words",
            system_prompt=base_system_prompt,
            model="deepseek-chat",
            max_tokens=4000,
            temperature=0.4
        )
    
    # Step 2: Parse and expand each major section
    sections = []
    current_section_lines = []
    
    for line in outline.split('\n'):
        if line.startswith('## ') and current_section_lines:
            sections.append('\n'.join(current_section_lines))
            current_section_lines = [line]
        elif line.strip():
            current_section_lines.append(line)
    
    if current_section_lines:
        sections.append('\n'.join(current_section_lines))
    
    # Limit to reasonable number of sections
    sections = [s for s in sections if s.strip()][:max_sections]
    
    rerank_logger.info(f"Expanding {len(sections)} sections")
    
    # Generate content for each section
    full_content_parts = []
    for i, section in enumerate(sections):
        if not section.strip():
            continue
            
        section_prompt = f"""Write a comprehensive section for a technical article in PLAIN TEXT FORMAT.

Topic: {query}

Section outline to expand:
{section}

Use this context as reference:
{context[:1500]}

CRITICAL FORMAT REQUIREMENTS:
- Write 400-600 words for this section
- Use SINGLE-COLUMN plain text only (no multi-column layouts)
- Describe ALL mathematical formulas in readable English words, NEVER use LaTeX
  - Example: write "the expected value of Q given theta" instead of "\\mathbb{E}[Q_\\theta]"
  - Example: write "alpha plus beta equals gamma" instead of "$\\alpha + \\beta = \\gamma$"
- If explaining algorithms, use step-by-step descriptions in words, not code or pseudocode blocks
- Be detailed, technical, and authoritative
- Do NOT use phrases like "based on the context" or "according to the documents"
- Use your extensive knowledge freely - you are the expert

Write the complete section now:"""

        try:
            section_content = await deepseek_complete(
                prompt=section_prompt,
                system_prompt=base_system_prompt,
                model="deepseek-chat",
                max_tokens=1200,
                temperature=0.4
            )
            full_content_parts.append(section_content)
            rerank_logger.info(f"Generated section {i+1}/{len(sections)} ({len(section_content.split())} words)")
        except Exception as e:
            rerank_logger.error(f"Failed to generate section {i}: {e}")
            full_content_parts.append(f"\n\n## {section.split(chr(10))[0].replace('## ', '')}\n\n[Content generation in progress...]\n\n")
    
    # Combine all sections
    full_response = '\n\n'.join(full_content_parts)
    word_count = len(full_response.split())
    rerank_logger.info(f"Combined response: {word_count} words")
    
    # Add conclusion if we have substantial content
    if word_count > 500:
        try:
            conclusion_prompt = f"""Write a comprehensive conclusion (300-400 words) for an article about {query}.

The article covered these sections:
{outline[:1000]}

Your conclusion should:
1. Synthesize the key insights
2. Discuss implications and future directions
3. Provide closing thoughts for practitioners and researchers"""

            conclusion = await deepseek_complete(
                prompt=conclusion_prompt,
                system_prompt=base_system_prompt,
                model="deepseek-chat",
                max_tokens=800,
                temperature=0.4
            )
            full_response += f"\n\n## Conclusion and Future Directions\n\n{conclusion}"
            rerank_logger.info(f"Added conclusion, final word count: {len(full_response.split())}")
        except Exception as e:
            rerank_logger.warning(f"Failed to generate conclusion: {e}")
    
    return full_response

def is_source_relevant(source: str, query: str) -> bool:
    """
    Check if a source filename is relevant to the query.
    Returns True if source likely contains relevant content.
    """
    import re
    
    # Extract keywords from query (remove common words)
    query_lower = query.lower()
    stop_words = {'the', 'a', 'an', 'is', 'are', 'was', 'were', 'be', 'been', 'being',
                  'have', 'has', 'had', 'do', 'does', 'did', 'will', 'would', 'could',
                  'should', 'may', 'might', 'must', 'shall', 'can', 'need', 'dare',
                  'to', 'of', 'in', 'for', 'on', 'with', 'at', 'by', 'from', 'as',
                  'and', 'or', 'how', 'what', 'why', 'when', 'where', 'who', 'which',
                  'this', 'that', 'these', 'those', 'my', 'your', 'his', 'her', 'its',
                  'our', 'their', 'me', 'you', 'him', 'her', 'us', 'them', 'it', 'i'}
    
    # Extract keywords from query
    query_words = set()
    for word in re.findall(r'[a-zA-Z]+', query_lower):
        if len(word) > 3 and word not in stop_words:
            query_words.add(word)
    
    # Check if any query keyword appears in source filename
    source_lower = source.lower()
    matches = []
    for word in query_words:
        if word in source_lower:
            matches.append(word)
    
    # Source is relevant if it matches at least one keyword
    # OR if it's a technical/engineering document
    relevant_extensions = ['.pdf', '.txt', '.html', '.doc', '.docx']
    is_relevant = len(matches) > 0 or any(source_lower.endswith(ext) for ext in relevant_extensions)
    
    return is_relevant, matches


def is_chunk_content_relevant(content: str, query: str, min_matches: int = 3) -> bool:
    """
    STRICT Check if chunk content actually contains relevant keywords from query.
    Returns True ONLY if content has specific technical terms matching the query.
    """
    import re
    
    if not content or not query:
        return False, 0, []
    
    query_lower = query.lower()
