def validate_and_fix_citations(response: str, sources: list) -> tuple:
    """
    Validate that citations in the response match the actual sources.
    Returns corrected response and list of warnings.
    """
    import re
    
    warnings = []
    
    # Find all citations in format "Source X" or "[X]"
    citations_found = re.findall(r'Source\s+(\d+)', response, re.IGNORECASE)
    citations_found += re.findall(r'\[(\d+)\]', response)
    
    # Get unique citation numbers
    cited_numbers = set([int(c) for c in citations_found])
    valid_numbers = set(range(1, len(sources) + 1))
    
    # Check for invalid citations
    invalid_citations = cited_numbers - valid_numbers
    
    if invalid_citations:
        warnings.append(f"Invalid source citations found: {invalid_citations}")
        print(f"[CITATION WARNING] Invalid citations in response: {invalid_citations}")
        print(f"[CITATION WARNING] Valid source numbers: 1-{len(sources)}")
        print(f"[CITATION WARNING] Sources: {sources}")
        
        # Replace invalid citations with generic reference
        for invalid_num in invalid_citations:
            # Replace "Source X" with "the literature"
            response = re.sub(rf'Source\s+{invalid_num}(?!\d)', 'the literature', response, flags=re.IGNORECASE)
            response = re.sub(rf'\[{invalid_num}\](?!\d)', '', response)
    
    # Check if response cites sources not in filtered_result
    # This could indicate hallucination
    if cited_numbers and not any(f"Source {n}" in response for n in valid_numbers):
        warnings.append("Response may contain hallucinated citations")
        print(f"[CITATION WARNING] Response cites sources but none match available sources")
    
    return response, warnings


def is_source_filename_relevant(source: str, query: str) -> bool:
    """
    STRICT check: Source filename MUST contain at least one query keyword.
    This filters out completely unrelated documents.
    """
    import re
    
    if not source or not query:
        return False
    
    source_lower = source.lower()
    query_lower = query.lower()
    
    # Extract meaningful keywords from query (4+ chars)
    query_keywords = set()
    for word in re.findall(r'[a-zA-Z]+', query_lower):
        if len(word) >= 4 and word not in {'that', 'this', 'with', 'from', 'have', 'been', 'they', 'will', 'would', 'should'}:
            query_keywords.add(word)
    
    # Also add important 3-char terms
    for word in re.findall(r'[a-zA-Z]+', query_lower):
        if len(word) == 3 and word not in {'the', 'and', 'for', 'are', 'but', 'not', 'you', 'all', 'can', 'had', 'her', 'was', 'one', 'our', 'out', 'day', 'get', 'has', 'him', 'his', 'how', 'man', 'new', 'now', 'old', 'see', 'two', 'way', 'who', 'boy', 'did', 'its', 'let', 'put', 'say', 'she', 'too', 'use'}:
            query_keywords.add(word)
    
    # Check if ANY keyword appears in filename
    for keyword in query_keywords:
        if keyword in source_lower:
            return True, keyword
    
    # Check for domain-specific terms in filename
    packaging_terms = ['package', 'packaging', 'chip', 'die', 'wafer', 'semiconductor', 'hbm', 'cowos', 'interposer', 'tsv', 'bump', 'solder', 'substrate', 'dielectric', 'copper', 'pad', ' interconnect', 'microbump', 'heterogeneous', 'integration']
    bonding_terms = ['bond', 'bonding', 'hybrid', 'thermal', 'compression', 'fusion', 'direct', 'dielectric', 'copper', 'pad', 'interface']
    
    all_terms = packaging_terms + bonding_terms
    
    for term in all_terms:
        if term in source_lower:
            return True, term
    
    # REJECT if no match
    print(f"[FILENAME FILTER] REJECTED: '{source}' - no keywords match query: {query_keywords}")
    return False, None


